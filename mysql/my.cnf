[mysqld]
# Charset
character-set-server     = utf8mb4
collation-server         = utf8mb4_unicode_ci

# Fast import tuning — reduces fsync pressure during bulk loads
innodb_flush_log_at_trx_commit = 2
innodb_flush_method            = O_DIRECT
sync_binlog                    = 0
innodb_doublewrite             = 0

# Buffer pool — increase if you have RAM (default 128M is too low)
innodb_buffer_pool_size  = 512M
innodb_log_file_size     = 256M
innodb_log_buffer_size   = 64M

# Disable binary log — not needed for local dev, speeds up writes
skip-log-bin

# Timeouts for large dumps
net_read_timeout  = 3600
net_write_timeout = 3600
wait_timeout      = 3600

[client]
default-character-set = utf8mb4
